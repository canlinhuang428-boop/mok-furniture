rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // 产品图片：公开读取
    match /products/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    // 其他文件：登录后可写
    match /{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
